generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ItemStatus {
  SAFE
  LOST
  FOUND
  RECOVERED
}

enum MessageStatus {
  NEW
  READ
  RESOLVED
  SPAM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum BillingCycle {
  FREE
  MONTHLY
  YEARLY
  CUSTOM
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  FINDER_MESSAGE
  QR_SCAN
  ITEM_LOST
  ITEM_FOUND
  PAYMENT_SUCCESS
  SUBSCRIPTION_UPDATE
  SYSTEM
  FOUND_REPORT
  POSSIBLE_MATCH
  VERIFICATION_UPDATE
  RECOVERY_UPDATE
}

enum ConversationStatus {
  OPEN
  CLOSED
  SPAM
  RECOVERED
}

enum ChatSenderType {
  OWNER
  FINDER
  SYSTEM
  ADMIN
}

enum FoundReportStatus {
  NEW
  MATCHED
  CLOSED
  SPAM
}

enum FoundMatchStatus {
  PENDING
  OWNER_NOTIFIED
  REJECTED
  CONFIRMED
}

enum VerificationLevel {
  EMAIL
  MOBILE
  GOVERNMENT_ID
  PREMIUM
}

enum VerificationRequestType {
  EMAIL
  MOBILE
  GOVERNMENT_ID
  PREMIUM
}

enum VerificationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ItemVerificationType {
  INVOICE
  WARRANTY_CARD
  OWNERSHIP_PROOF
  SERIAL_NUMBER
  PRODUCT_BOX
  OTHER
}

enum ItemVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConversationVerificationStatus {
  PENDING
  QUESTIONS_SENT
  ANSWERED
  VERIFIED
  NOT_VERIFIED
}

enum ChatMessageStatus {
  SENT
  DELIVERED
  READ
}

enum VerificationQuestionStatus {
  DRAFT
  SENT
  ANSWERED
  VERIFIED
  REJECTED
}

enum RecoverySource {
  QR_SCAN
  RECOVERY_ID
  FOUND_REPORT
  AI_MATCH
  ADMIN
}

enum RecoveryStatus {
  REGISTERED
  LOST
  OWNER_NOTIFIED
  CHAT_STARTED
  VERIFYING_OWNERSHIP
  MEETING_SCHEDULED
  RETURNED
  COMPLETED
  STILL_MISSING
  FALSE_REPORT
  CANCELLED
}

enum RecoveryActorType {
  OWNER
  FINDER
  SYSTEM
  ADMIN
}

enum CommunityPostType {
  LOST_ITEM
  FOUND_ITEM
  MISSING_PET
  LOST_DOCUMENT
  FOUND_DOCUMENT
  VEHICLE
  NEED_HELP
  RECOVERED_ITEM
  SUCCESS_STORY
  COMMUNITY_UPDATE
}

enum CommunityItemCategory {
  MOBILE
  WALLET
  KEYS
  DOCUMENTS
  BAG
  PET
  VEHICLE
  ELECTRONICS
  JEWELLERY
  CLOTHING
  OTHER
}

enum CommunityPostStatus {
  DRAFT
  PUBLISHED
  CLAIM_PENDING
  VERIFICATION_PENDING
  RECOVERED
  CLOSED
  HIDDEN
  REMOVED
}

enum CommunityVisibility {
  PUBLIC
  FOLLOWERS_ONLY
  PRIVATE
  UNLISTED
}

enum CommunityContactPreference {
  PLATFORM_MESSAGE
  COMMENTS
  BOTH
  NO_DIRECT_CONTACT
}

enum CommunityModerationStatus {
  PENDING
  APPROVED
  FLAGGED
  REJECTED
  AUTO_HIDDEN
}

enum PostMediaType {
  IMAGE
  VIDEO
}

enum PostMediaProcessingStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
  REMOVED
}

enum CommunityReactionType {
  LIKE
  HELPFUL
  HOPE
  FOUND_IT
  CELEBRATE
}
enum CommentReactionType {
  LIKE
  HELPFUL
  CELEBRATE
}
enum CommunityCommentStatus {
  ACTIVE
  EDITED
  DELETED
  HIDDEN
  REMOVED
}
enum FollowStatus {
  ACTIVE
  PENDING
  BLOCKED
  REMOVED
}
enum CommunityShareType {
  COPY_LINK
  NATIVE_SHARE
  WHATSAPP
  INTERNAL_SHARE
  OTHER
}
enum CommunityReportTargetType {
  POST
  COMMENT
  USER
}
enum CommunityReportReason {
  SPAM
  FRAUD
  WRONG_INFORMATION
  HARASSMENT
  UNSAFE_CONTENT
  DUPLICATE_CONTENT
  ITEM_ALREADY_RECOVERED
  IMPERSONATION
  PRIVACY_VIOLATION
  SCAM_OR_PAYMENT_REQUEST
  OTHER
}
enum CommunityReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
  ACTION_TAKEN
}
enum CommunityNotificationType {
  POST_REACTION
  COMMENT_CREATED
  COMMENT_REPLY
  COMMENT_REACTION
  USER_MENTION
  NEW_FOLLOWER
  FOLLOW_REQUEST
  FOLLOW_ACCEPTED
  POSSIBLE_MATCH
  SOMEONE_FOUND_ITEM
  CLAIM_REQUEST
  VERIFICATION_UPDATE
  FINDER_MESSAGE
  QR_SCAN
  ITEM_RECOVERED
  POST_SAVED_MILESTONE
  REPORT_UPDATE
  ADMIN_UPDATE
  SECURITY_ALERT
}
enum CommunityActivityType {
  POST_CREATED
  POST_PUBLISHED
  POST_UPDATED
  POST_RECOVERED
  POST_CLOSED
  POST_REACTION_ADDED
  COMMENT_CREATED
  COMMENT_REPLIED
  COMMENT_EDITED
  COMMENT_DELETED
  COMMENT_REACTION_ADDED
  POST_SAVED
  USER_FOLLOWED
  POST_SHARED
  REPORT_CREATED
}
enum CommunityActivityVisibility {
  PUBLIC
  PRIVATE
  INTERNAL
}

model User {
  id                         String                    @id @default(cuid())
  name                       String
  email                      String                    @unique
  phone                      String?
  passwordHash               String
  role                       UserRole                  @default(USER)
  isBlocked                  Boolean                   @default(false)
  emailAlertsEnabled         Boolean                   @default(true)
  whatsappAlertsEnabled      Boolean                   @default(false)
  smsAlertsEnabled           Boolean                   @default(false)
  qrScanAlertsEnabled        Boolean                   @default(true)
  finderMessageAlertsEnabled Boolean                   @default(true)
  paymentAlertsEnabled       Boolean                   @default(true)
  whatsappNumber             String?
  smsNumber                  String?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  emailVerifiedAt            DateTime?
  mobileVerifiedAt           DateTime?
  governmentIdVerifiedAt     DateTime?
  premiumVerifiedUntil       DateTime?
  verificationLevel          VerificationLevel?
  trustScore                 Int                       @default(0)
  lastActiveAt               DateTime?
  items                      Item[]
  subscriptions              Subscription[]
  payments                   Payment[]
  bulkImportLogs             BulkImportLog[]
  notifications              Notification[]
  ownedConversations         Conversation[]            @relation("ConversationOwner")
  sentChatMessages           ChatMessage[]             @relation("ChatMessageSender")
  verificationRequests       UserVerificationRequest[]
  recoveryRequests           RecoveryRequest[]         @relation("RecoveryOwner")
  communityPosts             CommunityPost[]
  communityMedia             PostMedia[]
  postReactions PostReaction[]
  communityComments CommunityComment[]
  commentReactions CommentReaction[]
  savedPosts SavedPost[]
  followers UserFollow[] @relation("FollowingUser")
  following UserFollow[] @relation("FollowerUser")
  communityShares CommunityShare[]
  communityReports CommunityReport[] @relation("CommunityReporter")
  reportsAgainstUser CommunityReport[] @relation("CommunityReportedUser")
  communityNotifications CommunityNotification[] @relation("CommunityNotificationRecipient")
  communityNotificationActions CommunityNotification[] @relation("CommunityNotificationActor")
  communityNotificationPreference NotificationPreference?
  communityActivities CommunityActivity[] @relation("CommunityActivityActor")
  communityTargetActivities CommunityActivity[] @relation("CommunityActivityTarget")
  followerCount Int @default(0)
  followingCount Int @default(0)

  @@index([email])
}

model CommunityPost {
  id                 String                     @id @default(cuid())
  authorId           String
  itemId             String?                    @unique
  postType           CommunityPostType
  itemCategory       CommunityItemCategory
  title              String
  description        String
  status             CommunityPostStatus        @default(DRAFT)
  visibility         CommunityVisibility        @default(PUBLIC)
  rewardOffered      Boolean                    @default(false)
  rewardAmount       Decimal?                   @db.Decimal(10, 2)
  rewardCurrency     String                     @default("INR")
  eventDate          DateTime?
  publicLocationName String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  publicLatitude     Decimal?                   @db.Decimal(9, 6)
  publicLongitude    Decimal?                   @db.Decimal(9, 6)
  privateLatitude    Decimal?                   @db.Decimal(9, 6)
  privateLongitude   Decimal?                   @db.Decimal(9, 6)
  contactPreference  CommunityContactPreference @default(PLATFORM_MESSAGE)
  allowComments      Boolean                    @default(true)
  allowSharing       Boolean                    @default(true)
  isVerifiedPost     Boolean                    @default(false)
  isPinned           Boolean                    @default(false)
  moderationStatus   CommunityModerationStatus  @default(APPROVED)
  moderationReason   String?
  reactionCount      Int                        @default(0)
  commentCount       Int                        @default(0)
  shareCount         Int                        @default(0)
  saveCount          Int                        @default(0)
  viewCount          Int                        @default(0)
  publishedAt        DateTime?
  recoveredAt        DateTime?
  closedAt           DateTime?
  deletedAt          DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  author             User                       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  item               Item?                      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  media              PostMedia[]
  tags               CommunityPostTag[]
  reactions PostReaction[]
  comments CommunityComment[]
  saves SavedPost[]
  shares CommunityShare[]
  reports CommunityReport[]
  notifications CommunityNotification[]
  activities CommunityActivity[]

  @@index([authorId, createdAt])
  @@index([status, visibility, moderationStatus, publishedAt, id])
  @@index([postType, publishedAt])
  @@index([itemCategory, publishedAt])
  @@index([city, state, publishedAt])
  @@index([recoveredAt])
  @@index([deletedAt])
}

model PostMedia {
  id               String                    @id @default(cuid())
  postId           String?
  ownerId          String
  mediaType        PostMediaType
  url              String
  storageKey       String?
  thumbnailUrl     String?
  mimeType         String
  fileSize         Int
  width            Int?
  height           Int?
  duration         Int?
  altText          String
  sortOrder        Int                       @default(0)
  processingStatus PostMediaProcessingStatus @default(READY)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  deletedAt        DateTime?
  post             CommunityPost?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  owner            User                      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
  @@index([ownerId, processingStatus])
  @@index([deletedAt])
}

model CommunityTag {
  id          String             @id @default(cuid())
  slug        String             @unique
  displayName String
  createdAt   DateTime           @default(now())
  posts       CommunityPostTag[]
}

model CommunityPostTag {
  postId String
  tagId  String
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    CommunityTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model PostReaction {
  id String @id @default(cuid())
  postId String
  userId String
  reactionType CommunityReactionType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([postId, userId])
  @@index([postId, reactionType])
  @@index([userId, createdAt])
}
model CommunityComment {
  id String @id @default(cuid())
  postId String
  authorId String
  parentId String?
  rootCommentId String?
  content String
  status CommunityCommentStatus @default(ACTIVE)
  depth Int @default(0)
  editedAt DateTime?
  deletedAt DateTime?
  reactionCount Int @default(0)
  replyCount Int @default(0)
  moderationStatus CommunityModerationStatus @default(APPROVED)
  moderationReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent CommunityComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies CommunityComment[] @relation("CommentReplies")
  reactions CommentReaction[]
  reports CommunityReport[]
  notifications CommunityNotification[]
  activities CommunityActivity[]
  @@index([postId, parentId, createdAt, id])
  @@index([authorId, createdAt])
  @@index([rootCommentId])
}
model CommentReaction {
  id String @id @default(cuid())
  commentId String
  userId String
  reactionType CommentReactionType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comment CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([commentId, userId])
  @@index([commentId, reactionType])
  @@index([userId, createdAt])
}
model SavedPost {
  id String @id @default(cuid())
  userId String
  postId String
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([userId, postId])
  @@index([userId, createdAt, id])
}
model UserFollow {
  id String @id @default(cuid())
  followerId String
  followingId String
  status FollowStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  follower User @relation("FollowerUser", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("FollowingUser", fields: [followingId], references: [id], onDelete: Cascade)
  @@unique([followerId, followingId])
  @@index([followerId, status, createdAt])
  @@index([followingId, status, createdAt])
}
model CommunityShare {
  id String @id @default(cuid())
  postId String
  userId String?
  anonymousSessionHash String?
  shareType CommunityShareType
  destination String?
  dedupeKey String?
  createdAt DateTime @default(now())
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([dedupeKey])
}
model CommunityReport {
  id String @id @default(cuid())
  reporterId String
  targetType CommunityReportTargetType
  targetPostId String?
  targetCommentId String?
  targetUserId String?
  reason CommunityReportReason
  details String?
  status CommunityReportStatus @default(OPEN)
  assignedAdminId String?
  resolution String?
  resolvedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reporter User @relation("CommunityReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetPost CommunityPost? @relation(fields: [targetPostId], references: [id], onDelete: SetNull)
  targetComment CommunityComment? @relation(fields: [targetCommentId], references: [id], onDelete: SetNull)
  targetUser User? @relation("CommunityReportedUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  @@index([reporterId, createdAt])
  @@index([targetType, status, createdAt])
  @@index([targetPostId])
  @@index([targetCommentId])
  @@index([targetUserId])
}
model CommunityNotification {
  id String @id @default(cuid())
  recipientId String
  actorId String?
  type CommunityNotificationType
  postId String?
  commentId String?
  relatedUserId String?
  activityId String?
  titleKey String
  messageKey String
  metadata Json?
  dedupeKey String?
  isRead Boolean @default(false)
  readAt DateTime?
  createdAt DateTime @default(now())
  deletedAt DateTime?
  recipient User @relation("CommunityNotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor User? @relation("CommunityNotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  post CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  @@unique([recipientId, dedupeKey])
  @@index([recipientId, isRead, createdAt, id])
}
model NotificationPreference {
  id String @id @default(cuid())
  userId String @unique
  inAppReactions Boolean @default(true)
  inAppComments Boolean @default(true)
  inAppReplies Boolean @default(true)
  inAppFollows Boolean @default(true)
  inAppMentions Boolean @default(true)
  inAppItemUpdates Boolean @default(true)
  emailCommunity Boolean @default(false)
  pushCommunity Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model CommunityActivity {
  id String @id @default(cuid())
  actorId String
  activityType CommunityActivityType
  postId String?
  commentId String?
  targetUserId String?
  metadata Json?
  visibility CommunityActivityVisibility @default(PUBLIC)
  createdAt DateTime @default(now())
  actor User @relation("CommunityActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  post CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  targetUser User? @relation("CommunityActivityTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  @@index([actorId, createdAt, id])
  @@index([postId, createdAt])
}

model Item {
  id                    String                 @id @default(cuid())
  userId                String
  itemName              String
  category              String
  description           String
  imageUrl              String?
  status                ItemStatus             @default(SAFE)
  lostModeEnabled       Boolean                @default(false)
  rewardAmount          Decimal?               @db.Decimal(10, 2)
  contactPreference     String
  recoveryCode          String?                @unique
  brand                 String?
  modelNumber           String?
  color                 String?
  identifyingMarks      String?
  purchaseDate          DateTime?
  estimatedValue        Decimal?               @db.Decimal(12, 2)
  recoveryPreference    String?
  visibility            String                 @default("PRIVATE")
  emergencyContact      String?
  lostDate              DateTime?
  lastSeenLocation      String?
  publicSearchVisible   Boolean                @default(false)
  qrRecoveryEnabled     Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCode                QRCode?
  scanLogs              ScanLog[]
  finderMessages        FinderMessage[]
  abuseReports          AbuseReport[]
  conversations         Conversation[]
  images                ItemImage[]
  verifications         ItemVerification[]
  foundReportMatches    FoundReportMatch[]
  verificationQuestions VerificationQuestion[]
  recoveryRequests      RecoveryRequest[]
  communityPost         CommunityPost?

  @@index([userId])
  @@index([status])
  @@index([category, status, publicSearchVisible])
  @@index([brand, color])
}

model ItemImage {
  id        String   @id @default(cuid())
  itemId    String
  imageUrl  String
  publicId  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortOrder])
}

model QRCode {
  id         String    @id @default(cuid())
  itemId     String    @unique
  uniqueCode String    @unique
  publicUrl  String
  imageUrl   String?
  createdAt  DateTime  @default(now())
  item       Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  scanLogs   ScanLog[]

  @@index([uniqueCode])
}

model ScanLog {
  id        String   @id @default(cuid())
  itemId    String
  qrCodeId  String?
  ipAddress String?
  userAgent String?
  location  String?
  scannedAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  qrCode    QRCode?  @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([qrCodeId])
  @@index([scannedAt])
}

model FinderMessage {
  id             String        @id @default(cuid())
  itemId         String
  finderName     String?
  finderPhone    String?
  finderEmail    String?
  finderMessage  String
  finderLocation String?
  finderPhotoUrl String?
  status         MessageStatus @default(NEW)
  createdAt      DateTime      @default(now())
  item           Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  abuseReports   AbuseReport[]
  conversation   Conversation?

  @@index([itemId])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id                    String                         @id @default(cuid())
  itemId                String
  ownerId               String
  finderMessageId       String?                        @unique
  finderName            String?
  finderPhone           String?
  finderEmail           String?
  finderAccessToken     String                         @unique
  status                ConversationStatus             @default(OPEN)
  verificationStatus    ConversationVerificationStatus @default(PENDING)
  foundReportId         String?
  finderIdentityId      String?
  lastMessageAt         DateTime?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  item                  Item                           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  owner                 User                           @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  finderMessage         FinderMessage?                 @relation(fields: [finderMessageId], references: [id], onDelete: SetNull)
  messages              ChatMessage[]
  foundReport           FoundReport?                   @relation(fields: [foundReportId], references: [id], onDelete: SetNull)
  finderIdentity        FinderIdentity?                @relation(fields: [finderIdentityId], references: [id], onDelete: SetNull)
  verificationQuestions VerificationQuestion[]
  recoveryRequests      RecoveryRequest[]

  @@index([ownerId, lastMessageAt])
  @@index([itemId])
  @@index([status])
  @@index([foundReportId])
  @@index([finderIdentityId])
}

model ChatMessage {
  id               String            @id @default(cuid())
  conversationId   String
  senderType       ChatSenderType
  senderUserId     String?
  message          String
  finderIdentityId String?
  imageUrl         String?
  locationJson     Json?
  status           ChatMessageStatus @default(SENT)
  isReadByOwner    Boolean           @default(false)
  isReadByFinder   Boolean           @default(false)
  createdAt        DateTime          @default(now())
  conversation     Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser       User?             @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  finderIdentity   FinderIdentity?   @relation(fields: [finderIdentityId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([conversationId, isReadByOwner])
  @@index([conversationId, isReadByFinder])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model FoundReport {
  id               String             @id @default(cuid())
  recoveryCode     String?
  category         String
  brand            String?
  modelNumber      String?
  color            String?
  identifyingMarks String?
  description      String
  foundLocation    String
  foundDate        DateTime
  photoUrl         String?
  finderName       String?
  finderPhone      String?
  finderWhatsapp   String?
  finderEmail      String?
  message          String
  status           FoundReportStatus  @default(NEW)
  finderIdentityId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  finderIdentity   FinderIdentity?    @relation(fields: [finderIdentityId], references: [id], onDelete: SetNull)
  images           FoundReportImage[]
  matches          FoundReportMatch[]
  conversations    Conversation[]
  recoveryRequests RecoveryRequest[]

  @@index([status, createdAt])
  @@index([category, foundLocation])
  @@index([recoveryCode])
}

model FoundReportImage {
  id            String      @id @default(cuid())
  foundReportId String
  imageUrl      String
  publicId      String?
  createdAt     DateTime    @default(now())
  foundReport   FoundReport @relation(fields: [foundReportId], references: [id], onDelete: Cascade)

  @@index([foundReportId])
}

model FoundReportMatch {
  id            String           @id @default(cuid())
  foundReportId String
  itemId        String
  matchScore    Int
  matchReason   String
  status        FoundMatchStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  foundReport   FoundReport      @relation(fields: [foundReportId], references: [id], onDelete: Cascade)
  item          Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([foundReportId, itemId])
  @@index([itemId, status])
}

model FinderIdentity {
  id                   String            @id @default(cuid())
  name                 String?
  phone                String?
  whatsapp             String?
  email                String?
  phoneVerifiedAt      DateTime?
  emailVerifiedAt      DateTime?
  reputationScore      Int               @default(0)
  successfulRecoveries Int               @default(0)
  helpfulReports       Int               @default(0)
  falseReports         Int               @default(0)
  avgResponseTime      Int?
  badges               Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  foundReports         FoundReport[]
  conversations        Conversation[]
  chatMessages         ChatMessage[]
  recoveryRequests     RecoveryRequest[]
}

model UserVerificationRequest {
  id                String                    @id @default(cuid())
  userId            String
  type              VerificationRequestType
  status            VerificationRequestStatus @default(PENDING)
  documentUrl       String?
  reviewedByAdminId String?
  rejectionReason   String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model ItemVerification {
  id                 String                 @id @default(cuid())
  itemId             String
  type               ItemVerificationType
  documentUrl        String?
  serialNumberMasked String?
  status             ItemVerificationStatus @default(PENDING)
  reviewedByAdminId  String?
  rejectionReason    String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  item               Item                   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, status])
}

model VerificationQuestion {
  id             String                     @id @default(cuid())
  conversationId String
  itemId         String
  question       String
  status         VerificationQuestionStatus @default(DRAFT)
  answer         String?
  askedByOwnerId String?
  answeredAt     DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  conversation   Conversation               @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  item           Item                       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([conversationId, status])
}

model RecoveryRequest {
  id                       String                  @id @default(cuid())
  itemId                   String
  ownerId                  String
  foundReportId            String?
  conversationId           String?
  finderIdentityId         String?
  source                   RecoverySource
  status                   RecoveryStatus          @default(REGISTERED)
  scheduledMeetingLocation String?
  scheduledMeetingTime     DateTime?
  ownerConfirmation        Boolean?
  finderConfirmation       Boolean?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  item                     Item                    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  owner                    User                    @relation("RecoveryOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  foundReport              FoundReport?            @relation(fields: [foundReportId], references: [id], onDelete: SetNull)
  conversation             Conversation?           @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  finderIdentity           FinderIdentity?         @relation(fields: [finderIdentityId], references: [id], onDelete: SetNull)
  timeline                 RecoveryTimelineEvent[]

  @@index([ownerId, status])
  @@index([itemId, createdAt])
}

model RecoveryTimelineEvent {
  id                String            @id @default(cuid())
  recoveryRequestId String
  type              String
  title             String
  description       String
  actorType         RecoveryActorType
  createdAt         DateTime          @default(now())
  recoveryRequest   RecoveryRequest   @relation(fields: [recoveryRequestId], references: [id], onDelete: Cascade)

  @@index([recoveryRequestId, createdAt])
}

model AbuseReport {
  id           String         @id @default(cuid())
  itemId       String?
  messageId    String?
  reportReason String
  reportedBy   String?
  createdAt    DateTime       @default(now())
  item         Item?          @relation(fields: [itemId], references: [id], onDelete: SetNull)
  message      FinderMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([messageId])
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("INR")
  billingCycle  BillingCycle
  itemLimit     Int
  features      Json
  isPopular     Boolean        @default(false)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
  payments      Payment[]

  @@index([billingCycle])
  @@index([isActive])
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  planId            String
  status            SubscriptionStatus @default(ACTIVE)
  startedAt         DateTime           @default(now())
  expiresAt         DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments          Payment[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([expiresAt])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  planId            String
  subscriptionId    String?
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  razorpayOrderId   String        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  paymentMethod     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              Plan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([planId])
  @@index([subscriptionId])
  @@index([status])
  @@index([createdAt])
}

model BulkImportLog {
  id            String   @id @default(cuid())
  userId        String
  fileName      String?
  totalRows     Int
  importedCount Int
  failedCount   Int
  errorSummary  Json?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}
